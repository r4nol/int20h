{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "SLO Error Budget dashboard: 99.9% availability SLO with multi-window burn rate detection (Google SRE Book methodology)",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "🎯 SLO Targets: Availability 99.9% | P99 Latency < 500ms",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.997 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "unit": "percentunit",
          "min": 0.99,
          "max": 1
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "titleSize": 14, "valueSize": 32 }
      },
      "targets": [
        {
          "expr": "1 - (sum(increase(http_requests_total{status_code=~\"5..\",namespace=\"production\"}[30d])) / sum(increase(http_requests_total{namespace=\"production\"}[30d])))",
          "legendFormat": "30d Availability"
        }
      ],
      "title": "Availability (30d) — SLO: 99.9%",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "titleSize": 14, "valueSize": 32 }
      },
      "targets": [
        {
          "expr": "clamp_min(1 - (sum(increase(http_requests_total{status_code=~\"5..\",namespace=\"production\"}[30d])) / sum(increase(http_requests_total{namespace=\"production\"}[30d])) / 0.001), 0)",
          "legendFormat": "Error Budget Remaining"
        }
      ],
      "title": "Error Budget Remaining (budget: 0.1%)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 14 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "(sum(rate(http_requests_total{status_code=~\"5..\",namespace=\"production\"}[1h])) / sum(rate(http_requests_total{namespace=\"production\"}[1h]))) / 0.001",
          "legendFormat": "1h Burn Rate"
        }
      ],
      "title": "1h Burn Rate (>14x = fast burn alert)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"production\",service=\"frontend\"}[5m])) by (le))",
          "legendFormat": "Frontend P99 Latency"
        }
      ],
      "title": "Frontend P99 Latency — SLO: < 500ms",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 10,
      "title": "🔥 Multi-Window Burn Rate (Google SRE Book — Chapter 5)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Fast burn: 1h burn rate > 14x AND 5m burn rate > 14x → page immediately\nSlow burn: 6h burn rate > 2x AND 1h burn rate > 2x → ticket",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 14 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Fast Burn (1h)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 3 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Slow Burn (6h)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 7 },
      "id": 11,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "(sum(rate(http_requests_total{status_code=~\"5..\",namespace=\"production\"}[1h])) / sum(rate(http_requests_total{namespace=\"production\"}[1h]))) / 0.001",
          "legendFormat": "Fast Burn (1h)"
        },
        {
          "expr": "(sum(rate(http_requests_total{status_code=~\"5..\",namespace=\"production\"}[6h])) / sum(rate(http_requests_total{namespace=\"production\"}[6h]))) / 0.001",
          "legendFormat": "Slow Burn (6h)"
        },
        {
          "expr": "14",
          "legendFormat": "Fast Burn Alert Threshold (14x)"
        },
        {
          "expr": "2",
          "legendFormat": "Slow Burn Alert Threshold (2x)"
        }
      ],
      "title": "Error Budget Burn Rate — Multi-Window (1x = depleting budget at SLO-defined rate)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 20,
      "title": "📉 Availability Over Time",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0.99,
          "max": 1,
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.997 },
              { "color": "green", "value": 0.999 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 21,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "1 - (sum(rate(http_requests_total{status_code=~\"5..\",namespace=\"production\"}[5m])) / sum(rate(http_requests_total{namespace=\"production\"}[5m])))",
          "legendFormat": "5m window availability"
        },
        {
          "expr": "0.999",
          "legendFormat": "SLO target 99.9%"
        }
      ],
      "title": "Rolling Availability vs SLO Target",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 22,
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"production\"}[5m])) by (service, le)) < 0.5",
          "legendFormat": "{{service}} P99 < 500ms (SLO compliant)"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"production\"}[5m])) by (service, le)) >= 0.5",
          "legendFormat": "{{service}} P99 ≥ 500ms (SLO BREACH)"
        }
      ],
      "title": "Latency SLO Compliance per Service (P99 < 500ms)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["online-boutique", "slo", "error-budget", "int20h"],
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Online Boutique — SLO Error Budget",
  "uid": "online-boutique-slo",
  "version": 1
}
